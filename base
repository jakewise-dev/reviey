func save_game():
    var save_data = {
        "ink_count": ink_count,
        "player_level": player_level,
        "player_exp": player_exp,
        "exp_to_next_level": exp_to_next_level,
        "my_collection": my_collection,
        "discovered_echoes": discovered_echoes,
        "library_exhibits": library_exhibits,
        "deployed_echoes": deployed_echoes,
        "boss_level": boss_level,
        "boss_hp": boss_hp,
        "boss_atk": boss_atk,
        "upgrades_unlocked": upgrades_unlocked,
        "last_save_time": Time.get_unix_time_from_system() 
    }
    var file = FileAccess.open(SAVE_PATH, FileAccess.WRITE)
    file.store_var(save_data)
    print("Game Saved successfully!")
    post_to_log("Game Saved to Hard Drive!")

func load_game():
    if not FileAccess.file_exists(SAVE_PATH):
        print("No save file found!")
        return
        
    var file = FileAccess.open(SAVE_PATH, FileAccess.READ)
    var save_data = file.get_var()
    
    ink_count = save_data.get("ink_count", ink_count)
    player_level = save_data.get("player_level", player_level)
    player_exp = save_data.get("player_exp", player_exp)
    exp_to_next_level = save_data.get("exp_to_next_level", exp_to_next_level)
    my_collection = save_data.get("my_collection", my_collection)
    discovered_echoes = save_data.get("discovered_echoes", discovered_echoes)
    library_exhibits = save_data.get("library_exhibits", library_exhibits)
    deployed_echoes = save_data.get("deployed_echoes", deployed_echoes)
    boss_level = save_data.get("boss_level", boss_level)
    boss_hp = save_data.get("boss_hp", boss_hp)
    boss_atk = save_data.get("boss_atk", boss_atk)
    upgrades_unlocked = save_data.get("upgrades_unlocked", upgrades_unlocked)
    
    var saved_time = save_data.get("last_save_time", 0.0)
    var total_offline_ink = 0.0
    
    if saved_time > 0:
        var seconds_away = Time.get_unix_time_from_system() - saved_time
        
        for key in library_exhibits.keys():
            var exhibit = library_exhibits[key]
            if not exhibit["unlocked"]: continue
            
            var exhibit_rate = 0.0
            for echo_name in exhibit["contents"]:
                var base = get_base_name(echo_name)
                if echo_database.has(base):
                    exhibit_rate += echo_database[base].ink_rate
            
            if exhibit_rate > 0:
                var possible_ink = exhibit_rate * seconds_away
                var space_left = exhibit["ink_cap"] - exhibit["ink_stored"]
                
                if possible_ink > space_left:
                    possible_ink = space_left
                    
                if possible_ink > 0:
                    exhibit["ink_stored"] += possible_ink
                    total_offline_ink += possible_ink

    selected_echo_name = ""
    library_roster_selected_name = ""
    inspected_exhibit_key = ""
    
    update_ui()
    print("Game Loaded successfully!")
    post_to_log("Game Loaded Successfully!")
    if total_offline_ink > 0:
        post_to_log("[color=cyan]Offline Progress: Pedestals generated " + str(int(total_offline_ink)) + " Ink![/color]")


