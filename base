# --- 5. HATCHERY & EXP ---

func gain_exp(amount):
    player_exp += amount
    if player_exp >= exp_to_next_level:
        player_level += 1
        player_exp -= exp_to_next_level
        exp_to_next_level = int(exp_to_next_level * 1.5)
        print("LEVEL UP! You are now Level ", player_level)

func find_free_slot():
    var total_slots = 3
    if upgrades_unlocked.slot_4: total_slots = 4
    for i in range(total_slots):
        if hatchery_slots_active[i] == false: return i
    return -1

func start_job(slot_idx, res_name, dur):
    hatchery_slots_active[slot_idx] = true
    var bar_path = "%HatcheryBar" + str(slot_idx + 1)
    if has_node(bar_path):
        var bar = get_node(bar_path)
        bar.value = 0
        var tw = create_tween()
        tw.tween_property(bar, "value", 100, dur)
        await get_tree().create_timer(dur).timeout
        tw.kill()
        bar.value = 0
        
        if not res_name in discovered_echoes: discovered_echoes.append(res_name)
        my_collection.append(res_name) 
        gain_exp(25)
        hatchery_slots_active[slot_idx] = false
        update_ui()

func _on_shop_button_pressed(): 
    var slot = find_free_slot()
    if slot == -1 or ink_count < 50: return
    ink_count -= 50
    
    var pool = ["Tide Echo", "Pyre Echo"]
    if player_level >= 3: pool.append("Tremor Echo")
    if player_level >= 5: pool.append("Zephyr Echo")
        
    var result = pool[randi() % pool.size()]
    start_job(slot, result, 5.0)
    update_ui()

func _on_weave_button_pressed():
    var slot = find_free_slot()
    if slot == -1 or parent_a_index == -1 or parent_b_index == -1: return
        
    var p1 = get_base_name(my_collection[parent_a_index])
    var p2 = get_base_name(my_collection[parent_b_index])
    var key = p1 + " + " + p2
    var alt = p2 + " + " + p1
    var res = ""
    
    if weighted_recipes.has(key): res = pick_weighted_result(weighted_recipes[key])
    elif weighted_recipes.has(alt): res = pick_weighted_result(weighted_recipes[alt])
    else: res = p1 if randf() > 0.5 else p2
            
    var final_time = echo_database[res]["time"] * weave_speed_mult
    start_job(slot, res, final_time)
    
    parent_a_index = -1
    parent_b_index = -1
    selected_echo_name = ""
    update_ui()

# --- 6. VISUAL LIBRARY LOGIC ---

func _on_library_roster_item_selected(idx):
    if idx < my_collection.size():
        library_roster_selected_name = my_collection[idx]

func try_place_in_exhibit(exhibit_key):
    if library_roster_selected_name == "": return 
        
    var exhibit_data = library_exhibits[exhibit_key]
    var base_name = get_base_name(library_roster_selected_name)
    var echo_data = echo_database[base_name]
    
    if not exhibit_data["type"] in echo_data.tags: return
    if exhibit_data["contents"].size() >= exhibit_data["capacity"]: return
        
    my_collection.erase(library_roster_selected_name)
    exhibit_data["contents"].append(library_roster_selected_name)
    library_roster_selected_name = ""

func handle_exhibit_click(key):
    var data = library_exhibits[key]
    if not data["unlocked"]:
        if ink_count >= data["cost"]:
            ink_count -= data["cost"]
            data["unlocked"] = true
            print("Restored ", data["name"], "!")
        else:
            print("Not enough ink to restore ", data["name"])
        update_ui()
        return
        
    inspected_exhibit_key = key
    selected_exhibit_content_index = -1
    if library_roster_selected_name != "":
        try_place_in_exhibit(key)
    update_ui()

func _on_tide_exhibit_pressed(): handle_exhibit_click("Tide")
func _on_pyre_exhibit_pressed(): handle_exhibit_click("Pyre")
func _on_tremor_exhibit_pressed(): handle_exhibit_click("Tremor")
func _on_zephyr_exhibit_pressed(): handle_exhibit_click("Zephyr")

func _on_exhibit_contents_list_item_selected(idx):
    selected_exhibit_content_index = idx

func _on_recall_from_exhibit_button_pressed():
    if inspected_exhibit_key == "" or selected_exhibit_content_index == -1: return
    var exhibit = library_exhibits[inspected_exhibit_key]
    if selected_exhibit_content_index < exhibit["contents"].size():
        var unit = exhibit["contents"][selected_exhibit_content_index]
        exhibit["contents"].remove_at(selected_exhibit_content_index)
        my_collection.append(unit)
        selected_exhibit_content_index = -1
        update_ui()

func _process(delta):
    var total_ready_to_collect = 0.0
    for key in library_exhibits.keys():
        var exhibit = library_exhibits[key]
        if not exhibit["unlocked"]: continue
        
        var exhibit_rate = 0.0
        for echo_name in exhibit["contents"]:
            var base = get_base_name(echo_name)
            if echo_database.has(base):
                exhibit_rate += echo_database[base].ink_rate
                
        if exhibit["ink_stored"] < exhibit["ink_cap"]:
            exhibit["ink_stored"] += exhibit_rate * delta
            if exhibit["ink_stored"] > exhibit["ink_cap"]:
                exhibit["ink_stored"] = exhibit["ink_cap"]
                
        total_ready_to_collect += exhibit["ink_stored"]
        
    if has_node("%CollectButton"):
        %CollectButton.text = "Collect (" + str(int(total_ready_to_collect)) + ")"

func _on_collect_button_pressed():
    var total_collected = 0
    for key in library_exhibits.keys():
        var exhibit = library_exhibits[key]
        if not exhibit["unlocked"]: continue
        total_collected += exhibit["ink_stored"]
        exhibit["ink_stored"] = 0.0
    ink_count += int(total_collected)
    update_ui()

# --- 7. TFT COMBAT LOGIC ---
func _on_deploy_button_pressed():
    if selected_echo_name != "" and selected_echo_name in my_collection:
        if deployed_echoes.size() < max_board_size:
            my_collection.erase(selected_echo_name)
            deployed_echoes.append(selected_echo_name)
            selected_echo_name = ""
            update_ui()

func _on_recall_button_pressed():
    if board_selected_index != -1 and board_selected_index < deployed_echoes.size():
        my_collection.append(deployed_echoes[board_selected_index])
        deployed_echoes.remove_at(board_selected_index)
        board_selected_index = -1
        update_ui()

# NEW: Combat Log Helper Function
func post_to_log(msg: String):
    if has_node("%BattleLog"):
        var log_node = get_node("%BattleLog")
        log_node.append_text(msg + "\n")

func _on_fight_button_pressed():
    if is_fighting or deployed_echoes.size() == 0: return
    is_fighting = true
    if has_node("%FightButton"): %FightButton.disabled = true
    
    var current_hp = 0
    var current_atk = 0
    var current_boss_atk = boss_atk
    var tags = {"Tide": 0, "Tremor": 0, "Pyre": 0, "Zephyr": 0}
    
    for i in deployed_echoes:
        var d = echo_database[get_base_name(i)]
        current_hp += d.hp
        current_atk += d.atk
        for t in d.tags: if tags.has(t): tags[t] += 1
    
    # Evaluate Combat Abilities based on tags
    var heal_per_turn = tags["Tide"] * 10      # Tide heals the board per turn
    var shield_block = tags["Tremor"] * 5      # Tremor blocks incoming damage
    var burn_per_turn = tags["Pyre"] * 15      # Pyre burns the boss per turn
    
    var active_boss_hp = boss_hp
    var active_player_hp = current_hp
    var max_player_hp = current_hp
    
    if has_node("%BossHPBar"):
        %BossHPBar.max_value = boss_hp
        %BossHPBar.value = active_boss_hp
    
    if has_node("%BattleLog"): 
        %BattleLog.text = "" # Clear the log for the new fight
    post_to_log("[color=yellow]--- BATTLE START (LV " + str(boss_level) + ") ---[/color]")
    
    while active_boss_hp > 0 and active_player_hp > 0:
        # 1. PLAYER ATTACKS
        active_boss_hp -= current_atk
        post_to_log("Board attacks for [color=yellow]" + str(current_atk) + "[/color] damage.")
        
        # 2. BURN EFFECT (Pyre)
        if burn_per_turn > 0:
            active_boss_hp -= burn_per_turn
            post_to_log("🔥 Pyre applies [color=orange]" + str(burn_per_turn) + " Burn[/color] damage!")
        
        if has_node("%BossHPBar"): %BossHPBar.value = active_boss_hp
        spawn_damage_text(current_atk + burn_per_turn, %BossLabel.global_position + Vector2(50,0), Color.YELLOW)
        apply_shake(%BossLabel, 10.0)
        await get_tree().create_timer(0.4).timeout
        
        if active_boss_hp <= 0: break
            
        # 3. BOSS ATTACKS & SHIELD (Tremor)
        var actual_boss_dmg = max(0, current_boss_atk - shield_block)
        active_player_hp -= actual_boss_dmg
        
        if shield_block > 0:
            post_to_log("Boss attacks for [color=red]" + str(actual_boss_dmg) + "[/color] (🪨 Blocked " + str(shield_block) + ").")
        else:
            post_to_log("Boss attacks for [color=red]" + str(actual_boss_dmg) + "[/color] damage.")
        
        # 4. HEAL EFFECT (Tide)
        if heal_per_turn > 0 and active_player_hp > 0:
            active_player_hp += heal_per_turn
            if active_player_hp > max_player_hp: active_player_hp = max_player_hp # Don't overheal
            post_to_log("🌊 Tide heals the board for [color=green]" + str(heal_per_turn) + "[/color] HP!")
            
        spawn_damage_text(actual_boss_dmg, Vector2(200, 400), Color.RED)
        apply_shake(self, 5.0)
        await get_tree().create_timer(0.4).timeout
    
    if active_boss_hp <= 0:
        post_to_log("[color=green]--- VICTORY ---[/color]")
        ink_count += 100 * boss_level
        var exp_reward = 50 * boss_level
        gain_exp(exp_reward)
        
        boss_level += 1
        boss_hp = int(boss_hp * 1.5)
        boss_atk = int(boss_atk * 1.2)
        post_to_log("Gained " + str(exp_reward) + " EXP!")
    else:
        post_to_log("[color=red]--- DEFEAT ---[/color]")
        post_to_log("Your board was wiped out.")
        
    is_fighting = false
    if has_node("%FightButton"): %FightButton.disabled = false
    update_ui()

