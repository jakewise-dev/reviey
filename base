func update_exhibit_button(btn_path, key):
    if not has_node(btn_path): return
    var data = library_exhibits[key]
    var btn = get_node(btn_path)
    
    if not data["unlocked"]:
        btn.text = "Restore " + data["name"] + "\nCost: " + str(data["cost"]) + " Ink"
    else:
        var t = data["name"] + "\n"
        t += "Echoes: " + str(data["contents"].size()) + "/" + str(data["capacity"]) + "\n"
        t += "Ink: " + str(int(data["ink_stored"])) + "/" + str(data["ink_cap"])
        btn.text = t

