@tool
extends Node2D

@export_group("Settings")
@export var habitat_type: String = "Tide" # Set to "Tide" or "Pyre"

@export_group("Visuals")
@export var tree_texture: Texture2D
@export var glow_color: Color = Color(1, 1, 1, 1) # White by default
@export var particle_color: Color = Color(1, 1, 1, 1)
@export_group("Setup")
@export var wisp_scene: PackedScene = preload("res://base_echo.tscn")

var last_seen_wisp_count = -1 # Add this variable at the top of the script!



func _ready():
    # 1. Apply the visuals we set in the Inspector
    if tree_texture:
        %TreeSprite.texture = tree_texture
    %Glow.color = glow_color
    %Particles1.modulate = particle_color
    %Particles2.modulate = particle_color
    
    # 2. Hide the icon at start
    %CollectIcon.visible = false

    # 3. Connect to the core (your existing code)
    await get_tree().process_frame
    var core = get_tree().root.find_child("ReverieCore", true, false)
    if core:
        core.ui_updated.connect(_on_core_updated)
        _on_core_updated()


    # Make the icon bob up and down forever
    var bounce = create_tween().set_loops()
    bounce.tween_property(%CollectIcon, "position:y", %CollectIcon.position.y - 10, 1.2).set_trans(Tween.TRANS_SINE)
    bounce.tween_property(%CollectIcon, "position:y", %CollectIcon.position.y, 1.2).set_trans(Tween.TRANS_SINE)




func _on_core_updated():
    if Engine.is_editor_hint(): return 
    
    var core = get_tree().root.find_child("ReverieCore", true, false)
    if core and core.library_exhibits.has(habitat_type):
        var exhibit = core.library_exhibits[habitat_type]
        var current_count = exhibit["contents"].size()
        
        # ONLY refresh visuals if a new wisp was added or one was removed
        if current_count != last_seen_wisp_count:
            refresh_visuals(current_count)
            last_seen_wisp_count = current_count
        
        # The Icon can still update visibility every second, that's fine!
        %CollectIcon.visible = (exhibit["ink_stored"] >= 10)

func refresh_visuals(count: int):
    # Clear old ones
    for child in get_children():
        if child.is_in_group("resident_wisps"):
            child.queue_free()
            
    var core = get_tree().root.find_child("ReverieCore", true, false)
    var contents = core.library_exhibits[habitat_type]["contents"]

    for i in range(contents.size()):
        var echo_name = contents[i]
        var new_wisp = wisp_scene.instantiate()
        add_child(new_wisp)
        new_wisp.add_to_group("resident_wisps")
        
        # Position them randomly around the tree
        new_wisp.position = Vector2(randf_range(-40, 40), randf_range(-50, 10))
        
        # Set color based on the echo database in Core
        var base_name = core.get_base_name(echo_name)
        if core.echo_database.has(base_name):
            new_wisp.modulate = core.echo_database[base_name].color
            
    


func _on_click_area_mouse_entered():
    # Only scale the tree, not the icon or the whole habitat!
    var tween = create_tween()
    tween.tween_property(%TreeSprite, "scale", Vector2(1.05, 1.05), 0.1)
    %TreeSprite.modulate = Color(1.2, 1.2, 1.2)

func _on_click_area_mouse_exited():
    var tween = create_tween()
    tween.tween_property(%TreeSprite, "scale", Vector2(1.0, 1.0), 0.1)
    %TreeSprite.modulate = Color(1, 1, 1)

# --- CLICK LOGIC ---
func _on_click_area_input_event(_viewport, event, _shape_idx):
    if event is InputEventMouseButton and event.button_index == MOUSE_BUTTON_LEFT and event.pressed:
        var core = get_tree().root.find_child("ReverieCore", true, false)
        if not core: return
        
        # JUST OPEN THE NEW TRAY! NO MORE AUTO-HARVEST!
        if core.has_method("show_habitat_footer"):
            core.show_habitat_footer(habitat_type)
            
        get_viewport().set_input_as_handled()
        
        
        
        # Add this inside your Tree's script!

func make_wisp_wander(wisp_sprite: Node2D):
    # Pick a random spot near the tree (Change the 50 to make the wander area bigger/smaller)
    var random_x = randf_range(-50, 50) 
    var random_y = randf_range(-30, 30)
    var target_position = Vector2(random_x, random_y)
    
    # Calculate how long the walk should take so they move at a steady speed
    var distance = wisp_sprite.position.distance_to(target_position)
    var walk_time = distance / 20.0 # Speed of the wisp
    
    # Flip the sprite left or right depending on which way it's walking!
    if target_position.x < wisp_sprite.position.x:
        wisp_sprite.scale.x = -abs(wisp_sprite.scale.x) # Face Left
    else:
        wisp_sprite.scale.x = abs(wisp_sprite.scale.x) # Face Right
    
    # Create the movement animation
    var walk_tween = create_tween()
    walk_tween.tween_property(wisp_sprite, "position", target_position, walk_time).set_trans(Tween.TRANS_SINE)
    
    # Wait a random amount of time (1 to 3 seconds), then wander again!
    var pause_time = randf_range(1.0, 3.0)
    walk_tween.tween_interval(pause_time)
    walk_tween.finished.connect(make_wisp_wander.bind(wisp_sprite))
